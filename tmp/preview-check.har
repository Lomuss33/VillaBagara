          "content": {
            "size": -1,
            "mimeType": "text/html",
            "text": "<!doctype html>\r\n<html lang=\"en\">\r\n    <head>\r\n        <meta charset=\"UTF-8\" />\r\n        <title>Portfolio by Lovro Musić</title>\r\n\r\n        <!-- FavIcon -->\r\n        <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\" />\r\n\r\n        <!-- Canonical URL -->\r\n        <link rel=\"canonical\" href=\"https://lovro-music.de/\" />\r\n\r\n        <!-- Meta: Configurations -->\r\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\r\n        <meta name=\"format-detection\" content=\"address=no\"/>\r\n        <meta name=\"color-scheme\" content=\"dark\">\r\n\r\n        <!-- Meta: SEO -->\r\n        <meta name=\"description\" content=\"Welcome to the personal website of Lovro Musić, showcasing his life and skills in the journey of becoming a hardware engineer.\"/>\r\n        <meta name=\"keywords\" content=\"resume, cv, Lovro Musić, lovromusic, react, hardware engineer, industrial production enthusiast\"/>\r\n        <meta name=\"robots\" content=\"index, follow\"/>\r\n        <meta name=\"googlebot\" content=\"index, follow\"/>\r\n        <meta name=\"google\" content=\"notranslate\"/>\r\n        <meta name=\"author\" content=\"Lovro Musić\"/>\r\n        <meta name=\"theme-color\" content=\"#111111\"/>\r\n\r\n        <!-- Open Graph / Facebook -->\r\n        <meta property=\"og:type\" content=\"website\" />\r\n        <meta property=\"og:url\" content=\"https://lovro-music.de/\" />\r\n        <meta property=\"og:title\" content=\"React Portfolio by Lovro Musić\" />\r\n        <meta property=\"og:description\" content=\"A futuristic React portfolio template by Lovro Musić.\" />\r\n        <meta property=\"og:image\" content=\"https://lovro-music.de/images/pictures/og-image.jpg\" />\r\n\r\n        <!-- Twitter -->\r\n        <meta property=\"twitter:card\" content=\"summary_large_image\" />\r\n        <meta property=\"twitter:url\" content=\"https://lovro-music.de/\" />\r\n        <meta property=\"twitter:title\" content=\"React Portfolio by Lovro Musić\" />\r\n        <meta property=\"twitter:description\" content=\"A futuristic React portfolio template by Lovro Musić.\" />\r\n        <meta property=\"twitter:image\" content=\"https://lovro-music.de/images/pictures/og-image.jpg\" />\r\n\r\n        <!-- Structured Data -->\r\n        <script type=\"application/ld+json\">\r\n        {\r\n            \"@context\": \"https://schema.org\",\r\n            \"@type\": \"Person\",\r\n            \"name\": \"React Portfolio Template\",\r\n            \"description\": \"A futuristic React portfolio by Lovro Music.\",\r\n            \"url\": \"https://lovro-music.de/\"\r\n        }\r\n        </script>\r\n\r\n        <!-- Fonts -->\r\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n        <link href=\"https://fonts.googleapis.com/css?family=Saira:400,700\" rel=\"stylesheet\" type=\"text/css\">\r\n        <link href=\"https://fonts.googleapis.com/css?family=Orbitron:400,700\" rel=\"stylesheet\" type=\"text/css\">\r\n        <link href=\"https://fonts.googleapis.com/css?family=Lato:400,700,400italic,700italic\" rel=\"stylesheet\" type=\"text/css\">\r\n      <script type=\"module\" crossorigin src=\"/assets/index-Cjf0MGsv.js\"></script>\n      <link rel=\"modulepreload\" crossorigin href=\"/assets/swiper-C4qgqOjU.js\">\n      <link rel=\"stylesheet\" crossorigin href=\"/assets/index-D-b4xJGm.css\">\n    </head>\r\n    <body style=\"background-color: #111111\">\r\n        <div id=\"root\"></div>\r\r\n    </body>\r\n</html>\r\n"
